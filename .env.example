# ===== 武鸣招聘平台 - 配置模板 =====
# 复制此文件为 .env 并填入真实值
# cp .env.example .env

# 管理员密码（必填）
ADMIN_PASSWORD=change_me_here

# 微信小程序 Secret（必填）
MINI_APPSECRET=your_app_secret_here

# 服务器配置（可选）
APP_HOST=127.0.0.1
APP_PORT=8080
APP_DEBUG=false

# 会话有效期（小时，可选）
SESSION_HOURS=72

# 数据库路径（可选）
DATABASE_PATH=wuming_recruitment.db

# 站点URL（可选）
SITE_URL=https://job.airabbit.cn
SITE_NAME=武鸣招聘

# CSS版本号（可选）
CSS_VERSION=v20260610b
